      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:ghostty.org)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(whoami)",
      "Bash(date)",
      "Bash(uname *)",
      "Bash(git fetch *)",
      "Bash(git fetch)",
      "Bash(git pull *)",
      "Bash(git pull)",
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git log)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git branch*)",
      "Bash(git show *)",
      "Bash(git remote *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(gh pr view *)",
      "Bash(gh pr list*)",
      "Bash(gh pr status*)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checkout *)",
      "Bash(gh pr create --draft *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(gh repo view *)",
      "Bash(gh api *)",
      "Bash(* | head *)",
      "Bash(* | tail *)",
      "Bash(* | wc *)",
      "Bash(* | sort *)",
      "Bash(* | grep *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(npx playwright test *)",
      "Bash(npx playwright test)",
      "Bash(npx playwright show-report *)",
      "Bash(npx playwright show-report)",
      "Bash(npx playwright --version)",
      "Bash(npx playwright list-files *)",
      "Bash(npx playwright list-files)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_type"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Write(~/.ssh/**)",
      "Bash(* ~/.ssh/*)",
      "Read(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Write(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Edit(~/.gnupg/**)",
      "Write(~/.gnupg/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Bash(gh issue delete *)",
      "Bash(gh run delete *)",
      "Bash(gh release delete *)",
      "Bash(gh repo delete *)"
    ]
  },
  "hooks": {
    "Notification": []
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "voiceEnabled": true,
  "effortLevel": "medium"
}
